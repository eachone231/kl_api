APP_NAME=kl_api
ENV=local
CORS_ORIGINS=*
LOG_LEVEL=INFO

JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MIN=60
AUTH_ENABLED=true

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PWD=
DB_NAME=kl_store

REDIS_CLUSTER_MODE=
REDIS_HOST=
REDIS_PORT=6379
REDIS_PWD=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
# (Gmail App Password)
SMTP_PASS=
SMTP_FROM=
RESET_BASE_URL=

# API -> WORKER : Job 처리 지시 전문
KL_WORKER_REDIS_STREAM=
# WORKER -> API : WORKER 처리결과 스트리밍
KL_WORKER_REDIS_TASK_STATUS_STREAM=

RAG_CHAT_TOP_K=5
